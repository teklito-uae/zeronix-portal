APP_NAME=Zeronix Portal
APP_ENV=production
APP_KEY=base64:uH53uW6lWvR14oTZW5+TSg0omCe2XDcTRfrUYvpqmIE=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://zeronixtech.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- HOSTINGER DATABASE SETTINGS ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=REPLACE_WITH_YOUR_HOSTINGER_DB_NAME
DB_USERNAME=REPLACE_WITH_YOUR_HOSTINGER_DB_USER
DB_PASSWORD=REPLACE_WITH_YOUR_HOSTINGER_DB_PASSWORD

# --- SESSION & CACHE ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

# --- CORS ---
# This allows your frontend to talk to the backend
CORS_ALLOWED_ORIGINS=https://zeronixtech.com

